---
import BaseLayout from '../layouts/BaseLayout.astro';
import { paths } from '../i18n/strings.ts';
---

<BaseLayout
  locale="en"
  pageId="approach"
  title="The Kipu Readiness Index"
  description="A structured diagnostic that tells you exactly where your organization stands on the path to becoming AI-native — and what to do next."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container-base">
      <p class="eyebrow">Our Framework</p>
      <h1 class="display">The Kipu<br />Readiness Index.</h1>
      <p class="lead">
        A structured diagnostic that tells you exactly where your organization
        stands on the path to becoming AI-native — and what to do next.
      </p>
    </div>
  </section>

  <hr class="rule" />

  <!-- Why -->
  <section class="why">
    <div class="container-base grid-2">
      <div>
        <p class="eyebrow">Why it exists</p>
        <h2>Most AI strategies fail before they begin.</h2>
      </div>
      <div class="stack">
        <p>
          Not because the technology isn't ready — but because the organization
          isn't. Data is fragmented. Talent is missing. Governance is unclear.
          Use cases are picked by enthusiasm, not leverage.
        </p>
        <p>
          The Kipu Readiness Index is the first step we take with every
          client. Three to four weeks. A clear score. A prioritized roadmap.
          No fluff.
        </p>
      </div>
    </div>
  </section>

  <!-- Five dimensions -->
  <section class="dimensions section-bg-soft">
    <div class="container">
      <div class="dimensions__head">
        <p class="eyebrow">The Framework</p>
        <h2>Five dimensions of readiness.</h2>
      </div>

      <ol class="dimensions__list">
        <li>
          <span class="dimensions__num">01</span>
          <div>
            <h3>Strategic Clarity</h3>
            <p>
              Are AI investments tied to specific business outcomes, or driven
              by pressure to "do something with AI"?
            </p>
          </div>
        </li>
        <li>
          <span class="dimensions__num">02</span>
          <div>
            <h3>Data Foundation</h3>
            <p>
              Is your data accessible, governed, and trustworthy enough to
              power decisions and models?
            </p>
          </div>
        </li>
        <li>
          <span class="dimensions__num">03</span>
          <div>
            <h3>Talent &amp; Operating Model</h3>
            <p>
              Do you have the roles, structures, and decision rights to
              execute? Or is AI sitting in one team, isolated from the
              business?
            </p>
          </div>
        </li>
        <li>
          <span class="dimensions__num">04</span>
          <div>
            <h3>Use Case Portfolio</h3>
            <p>
              Which use cases will move the P&amp;L? Which are noise? We score
              them by impact, feasibility, and time to value.
            </p>
          </div>
        </li>
        <li>
          <span class="dimensions__num">05</span>
          <div>
            <h3>Governance &amp; Risk</h3>
            <p>
              Are policies, controls, and accountability in place to scale AI
              responsibly?
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Deliverable -->
  <section class="deliverable">
    <div class="container-base grid-2">
      <div>
        <p class="eyebrow">The deliverable</p>
        <h2>What you walk away with.</h2>
      </div>
      <ul class="deliverable__list stack">
        <li>
          A <strong>Kipu Readiness Score</strong> across the five dimensions,
          benchmarked against peers.
        </li>
        <li>
          A <strong>prioritized 12-month roadmap</strong> with sequenced
          initiatives, owners, and success metrics.
        </li>
        <li>
          A <strong>shortlist of three to five use cases</strong> ranked by
          leverage and feasibility.
        </li>
        <li>
          An <strong>executive readout</strong> for your board or leadership
          team.
        </li>
      </ul>
    </div>
  </section>

  <!-- Process -->
  <section class="process section-bg-soft">
    <div class="container-base">
      <p class="eyebrow">How it works</p>
      <h2 class="process__title">Three to four weeks. Three phases.</h2>

      <div class="process__phases">
        <div class="phase">
          <p class="phase__week">Week 1</p>
          <h3>Discovery</h3>
          <p>Stakeholder interviews, data audit, document review.</p>
        </div>
        <div class="phase">
          <p class="phase__week">Week 2</p>
          <h3>Diagnosis</h3>
          <p>Scoring, peer benchmarking, use-case ranking.</p>
        </div>
        <div class="phase">
          <p class="phase__week">Weeks 3–4</p>
          <h3>Roadmap &amp; Readout</h3>
          <p>Sequenced 12-month plan, executive presentation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="container-base">
      <p class="eyebrow">FAQ</p>
      <h2>Frequently asked.</h2>

      <dl class="faq__list">
        <div>
          <dt>Who is this for?</dt>
          <dd>
            Mid-sized and large enterprises in Latin America with serious
            intent to operate as AI-native — usually $50M+ in revenue, with
            leadership commitment from the CEO or COO.
          </dd>
        </div>
        <div>
          <dt>What does it cost?</dt>
          <dd>Fixed scope, fixed fee. We share the number on the intro call.</dd>
        </div>
        <div>
          <dt>What happens after?</dt>
          <dd>
            Most clients move into one of two next steps: a Capability Building
            program for their teams, or an Implementation engagement on the
            top-ranked use case. You're under no obligation to do either.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="closer section-bg-accent">
    <div class="container-base closer__inner">
      <h2 class="closer__title">Find out where you stand.</h2>
      <p class="closer__body">
        A 30-minute intro call costs nothing. We'll tell you whether the
        Readiness Index makes sense for your organization, and what we'd cover
        if it does.
      </p>
      <a href={paths.en.contact} class="btn btn-arrow closer__cta">Talk to us</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { padding-block: clamp(var(--space-12), 12vw, var(--space-20)); }
  .why { padding-block: clamp(var(--space-12), 10vw, var(--space-16)); }
  .why h2 { font-size: var(--type-h1); }

  .dimensions__head { max-width: 40ch; margin-bottom: var(--space-8); }
  .dimensions__head h2 { font-size: var(--type-h1); margin-top: var(--space-2); }

  .dimensions__list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: dim;
  }
  .dimensions__list > li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-line);
  }
  .dimensions__list > li:last-child { border-bottom: 1px solid var(--color-line); }
  .dimensions__num {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-accent);
    letter-spacing: var(--tracking-wide);
    margin-top: 0.4em;
  }
  .dimensions__list h3 { margin-bottom: var(--space-1); }

  .deliverable h2 { font-size: var(--type-h1); margin-top: var(--space-2); }
  .deliverable__list { list-style: none; padding: 0; }
  .deliverable__list li { padding-left: 1.6em; position: relative; }
  .deliverable__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0.05em;
    color: var(--color-accent);
  }

  .process__title { font-size: var(--type-h1); margin-top: var(--space-2); margin-bottom: var(--space-8); }
  .process__phases {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .process__phases { grid-template-columns: repeat(3, 1fr); gap: var(--space-8); }
  }
  .phase { padding-top: var(--space-3); border-top: 1px solid var(--color-line); }
  .phase__week {
    font-family: var(--font-body);
    font-size: var(--type-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 var(--space-2);
  }
  .phase h3 { margin-bottom: var(--space-2); }

  .faq__list { display: flex; flex-direction: column; margin-top: var(--space-6); }
  .faq__list > div {
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }
  @media (min-width: 768px) {
    .faq__list > div { grid-template-columns: 1fr 2fr; gap: var(--space-6); }
  }
  .faq__list > div:last-child { border-bottom: 1px solid var(--color-line); }
  dt { font-family: var(--font-display); font-size: var(--type-h3); font-weight: 500; }
  dd { margin: 0; }

  .closer__inner { text-align: center; display: grid; gap: var(--space-3); justify-items: center; }
  .closer__title { font-size: var(--type-display); line-height: var(--leading-tight); }
  .closer__body { color: color-mix(in srgb, var(--color-accent-ink) 88%, transparent); max-width: 50ch; }
  .closer__cta { margin-top: var(--space-4); border-color: var(--color-accent-ink); color: var(--color-accent-ink); }
  .closer__cta:hover { background: var(--color-accent-ink); color: var(--color-accent); border-color: var(--color-accent-ink); }
</style>
