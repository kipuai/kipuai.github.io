---
import BaseLayout from '../layouts/BaseLayout.astro';
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? 'YOUR_FORM_ID';
const formAction = `https://formspree.io/f/${formspreeId}`;
---

<BaseLayout
  locale="en"
  pageId="contact"
  title="Contact"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container-base" data-reveal>
      <p class="eyebrow">Contact</p>
      <h1 class="display">
        Tell us what<br />you're working on.
      </h1>
      <p class="lead">
        A 30-minute intro call is free. We'll tell you honestly whether we're
        the right partner — and if not, who might be.
      </p>
    </div>
  </section>

  <hr class="rule" />

  <!-- Intake -->
  <section class="intake">
    <div class="container-base grid-2">
      <div>
        <p class="eyebrow">Intake</p>
        <h2>Send us a few details.</h2>
        <p class="intake__hint">
          We reply within one business day. Prefer email?
          <a href="mailto:contact@kipuai.com">contact@kipuai.com</a>
        </p>
      </div>

      <form class="form stack" method="post" action={formAction} data-contact-form aria-label="Contact form">
        <input type="hidden" name="_subject" value="New Kipu intake" />
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="visually-hidden" aria-hidden="true" />
        <label class="field">
          <span>Your name<span class="req" aria-hidden="true">*</span></span>
          <input type="text" name="name" required autocomplete="name" />
        </label>

        <label class="field">
          <span>Work email<span class="req" aria-hidden="true">*</span></span>
          <input type="email" name="email" required autocomplete="email" />
        </label>

        <div class="grid-2 form__row">
          <label class="field">
            <span>Company<span class="req" aria-hidden="true">*</span></span>
            <input type="text" name="company" required autocomplete="organization" />
          </label>
          <label class="field">
            <span>Your role<span class="req" aria-hidden="true">*</span></span>
            <input type="text" name="role" required autocomplete="organization-title" />
          </label>
        </div>

        <div class="grid-2 form__row">
          <label class="field">
            <span>Company size (employees)</span>
            <select name="size">
              <option value="">Select…</option>
              <option>1–50</option>
              <option>51–250</option>
              <option>251–1000</option>
              <option>1000+</option>
            </select>
          </label>
          <label class="field">
            <span>Country</span>
            <input type="text" name="country" autocomplete="country-name" />
          </label>
        </div>

        <label class="field">
          <span>What kind of help?<span class="req" aria-hidden="true">*</span></span>
          <select name="help_type" required>
            <option value="">Select…</option>
            <option>Strategy / roadmap</option>
            <option>Hands-on build</option>
            <option>Team augmentation</option>
            <option>Audit or assessment</option>
            <option>Not sure yet</option>
          </select>
        </label>

        <label class="field">
          <span>Anything you'd like us to know? (optional)</span>
          <textarea name="message" rows="5" placeholder="A sentence on what you're trying to solve helps us prep."></textarea>
        </label>

        <div class="grid-2 form__row">
          <label class="field">
            <span>Ideal timeline</span>
            <select name="timeline">
              <option value="">Select…</option>
              <option>Urgent / starting now</option>
              <option>This quarter</option>
              <option>Next quarter</option>
              <option>6+ months out</option>
              <option>Just exploring</option>
            </select>
          </label>
          <label class="field">
            <span>How did you find us?</span>
            <select name="source">
              <option value="">Select…</option>
              <option>Referral</option>
              <option>LinkedIn</option>
              <option>Search</option>
              <option>Event or talk</option>
              <option>Press / podcast</option>
              <option>Other</option>
            </select>
          </label>
        </div>

        <button type="submit" class="btn btn-primary btn-arrow form__submit" data-magnetic>
          Send
        </button>

        <p class="form__status" data-form-status role="status" aria-live="polite"></p>
        <p class="form__success" data-form-success hidden>
          Thanks — we got it. We'll reply within one business day.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  function bindContactForm() {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form || (form as any)._kipuBound) return;
    (form as any)._kipuBound = true;

    const status = form.querySelector<HTMLElement>('[data-form-status]');
    const success = form.querySelector<HTMLElement>('[data-form-success]');

    form.addEventListener('submit', async (e) => {
      if (form.action.includes('YOUR_FORM_ID')) return; // let it fall through if unconfigured
      e.preventDefault();
      if (status) { status.textContent = 'Sending…'; status.removeAttribute('data-state'); }

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.querySelectorAll('input, select, textarea, button').forEach(el => (el as HTMLInputElement).disabled = true);
          if (status) status.textContent = '';
          if (success) success.hidden = false;
        } else {
          const data = await res.json().catch(() => ({} as any));
          if (status) {
            status.textContent = data?.errors?.[0]?.message ?? 'Something went wrong. Please email contact@kipuai.com.';
            status.setAttribute('data-state', 'error');
          }
        }
      } catch {
        if (status) {
          status.textContent = 'Network error. Please email contact@kipuai.com.';
          status.setAttribute('data-state', 'error');
        }
      }
    });
  }
  document.addEventListener('astro:page-load', bindContactForm);
  if (document.readyState !== 'loading') bindContactForm();
  else document.addEventListener('DOMContentLoaded', bindContactForm);
</script>

<style>
  .hero { padding-block: clamp(var(--space-12), 12vw, var(--space-20)); }
  .hero .lead { margin-top: var(--space-4); }

  .intake { padding-block: clamp(var(--space-12), 10vw, var(--space-16)); }
  .intake h2 { font-size: var(--type-h1); margin-top: var(--space-2); }
  .intake__hint { color: var(--color-ink-muted); font-size: var(--type-small); margin-top: var(--space-2); }
  .intake__hint a { color: var(--color-accent); }

  .form { max-width: 32rem; }
  .form__row { gap: var(--space-3); }

  .field { display: grid; gap: 0.5em; }
  .field > span { font-size: var(--type-small); font-weight: 500; }
  .req { color: var(--color-accent); margin-left: 0.2em; }

  .field input,
  .field select,
  .field textarea {
    font: inherit;
    font-size: var(--type-body);
    padding: 0.7em 0.9em;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-line);
    color: var(--color-ink);
    border-radius: 0;
    transition: border-color var(--duration-fast) var(--ease-out);
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-color: var(--color-ink);
    outline: none;
  }
  .field textarea { resize: vertical; min-height: 8rem; }

  .form__submit { justify-self: start; margin-top: var(--space-2); }
  .form__status { font-size: var(--type-small); color: var(--color-ink-muted); margin-top: var(--space-2); min-height: 1.4em; }
  .form__status[data-state="error"] { color: #b04545; }
  .form__success {
    font-size: var(--type-body); color: var(--color-accent);
    border-top: 1px solid var(--color-line); padding-top: var(--space-3); margin-top: var(--space-3);
  }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>
